# ============================================================
# DesignAI — Environment Variables Template
# Copy to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================

# ── AI ──────────────────────────────────────────────────────
# Anthropic Claude (claude-sonnet-4-6) for feasibility checks
ANTHROPIC_API_KEY=sk-ant-...

# ── Mapping ─────────────────────────────────────────────────
# Mapbox (satellite tiles + parcel drawing)
# NEXT_PUBLIC_ prefix = exposed to the browser (required for map rendering)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1...
MAPBOX_TOKEN=pk.eyJ1...        # server-side only (if needed)

# Google Maps (alternative / geocoding)
GOOGLE_MAPS_API_KEY=AIza...

# ── Supabase ─────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...  # Server-only, never expose to browser
# Get JWT secret from: Supabase Dashboard → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ── Database ─────────────────────────────────────────────────
# PostgreSQL connection string (for production; SQLite for local dev)
DATABASE_URL=postgresql://designai:password@localhost:5432/designai

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Security ─────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=changeme_generate_a_real_secret_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Storage ──────────────────────────────────────────────────
# S3-compatible storage for 3D exports and PDF reports
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=designai-exports

# ── App ──────────────────────────────────────────────────────
ENVIRONMENT=development
# Public URL for Next.js to talk to FastAPI
NEXT_PUBLIC_API_URL=http://localhost:8000
# App's own public URL (for webhooks, email links)
APP_URL=http://localhost:3000

# ── Celery ───────────────────────────────────────────────────
CELERY_CONCURRENCY=4

# ── Email (optional, for report delivery) ───────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=
EMAIL_FROM=noreply@designai.app
