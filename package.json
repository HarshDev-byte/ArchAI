{
  "name": "designai",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/web",
    "build": "npm run build --workspace=apps/web",
    "lint": "npm run lint --workspace=apps/web",
    "type-check": "npm run type-check --workspace=apps/web",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "api:install": "cd apps/api && pip install -r requirements.txt",
    "api:dev": "cd apps/api && uvicorn main:app --reload --port 8000",
    "worker:dev": "cd apps/api && celery -A workers.tasks worker --loglevel=info"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "turbo": "^2.3.3"
  }
}
